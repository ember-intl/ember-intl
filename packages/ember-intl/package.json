{
  "name": "ember-intl",
  "version": "7.0.7",
  "description": "Internationalization for Ember projects",
  "keywords": [
    "ember",
    "ember-addon",
    "ember-intl",
    "i18n",
    "internationalization"
  ],
  "homepage": "https://ember-intl.github.io/ember-intl/",
  "repository": {
    "type": "git",
    "url": "https://github.com/ember-intl/ember-intl.git"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./declarations/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./declarations/*.d.ts",
      "default": "./dist/*.js"
    },
    "./addon-main.js": "./addon-main.cjs"
  },
  "typesVersions": {
    "*": {
      "*": [
        "declarations/*"
      ]
    }
  },
  "files": [
    "addon-main.cjs",
    "declarations",
    "dist"
  ],
  "scripts": {
    "build": "concurrently 'pnpm:build:*' --names 'build:'",
    "build:js": "rollup --config",
    "build:types": "glint --declaration",
    "lint": "concurrently 'pnpm:lint:*(!fix)' --names 'lint:'",
    "lint:fix": "concurrently 'pnpm:lint:*:fix' --names 'fix:'",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "glint",
    "prepack": "rollup --config",
    "start": "concurrently 'pnpm:start:*' --names 'start:'",
    "start:js": "rollup --config --watch --no-watch.clearScreen",
    "start:types": "glint --declaration --watch",
    "test": "echo 'A v2 addon does not have tests, run tests in tests/ember-intl'"
  },
  "dependencies": {
    "@embroider/addon-shim": "^1.8.9",
    "@formatjs/intl": "^2.10.8",
    "decorator-transforms": "^2.2.2",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.8",
    "@babel/plugin-transform-typescript": "^7.25.7",
    "@babel/runtime": "^7.25.7",
    "@ember/test-helpers": "^4.0.4",
    "@embroider/addon-dev": "^6.0.1",
    "@glimmer/component": "^1.1.2",
    "@glimmer/tracking": "^1.1.2",
    "@glint/core": "^1.4.0",
    "@glint/environment-ember-loose": "^1.4.0",
    "@glint/environment-ember-template-imports": "^1.4.0",
    "@glint/template": "^1.4.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@shared-configs/ember-template-lint": "workspace:*",
    "@shared-configs/eslint-config-ember": "workspace:*",
    "@shared-configs/prettier": "workspace:*",
    "@shared-configs/typescript": "workspace:*",
    "babel-plugin-ember-template-compilation": "^2.3.0",
    "concurrently": "^9.0.1",
    "ember-qunit": "^8.1.0",
    "ember-source": "~5.12.0",
    "ember-template-lint": "^6.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "rollup": "^4.24.0",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "@ember/test-helpers": "^2.9.4 || ^3.2.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@ember/test-helpers": {
      "optional": false
    }
  },
  "engines": {
    "node": "18.* || >= 20"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "app-js": {
      "./helpers/format-date.js": "./dist/_app_/helpers/format-date.js",
      "./helpers/format-list.js": "./dist/_app_/helpers/format-list.js",
      "./helpers/format-message.js": "./dist/_app_/helpers/format-message.js",
      "./helpers/format-number.js": "./dist/_app_/helpers/format-number.js",
      "./helpers/format-relative.js": "./dist/_app_/helpers/format-relative.js",
      "./helpers/format-time.js": "./dist/_app_/helpers/format-time.js",
      "./helpers/t.js": "./dist/_app_/helpers/t.js",
      "./services/intl.js": "./dist/_app_/services/intl.js"
    },
    "demoURL": "https://ember-intl.github.io/ember-intl/",
    "main": "addon-main.cjs",
    "type": "addon",
    "version": 2
  }
}
