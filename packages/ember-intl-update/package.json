{
  "name": "@ember-intl/update",
  "version": "0.4.1",
  "description": "Codemod to update ember-intl to the next major version",
  "keywords": [
    "codemod",
    "ember",
    "ember-codemod",
    "ember-intl",
    "emberjs"
  ],
  "homepage": "https://ember-intl.github.io/ember-intl/",
  "repository": {
    "type": "git",
    "url": "https://github.com/ember-intl/ember-intl.git",
    "directory": "packages/ember-intl-update"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": "dist/bin/ember-intl-update.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "sh build.sh --production",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "tsc --noEmit",
    "prepare": "pnpm build",
    "test": "sh build.sh --test && mt dist-for-testing --quiet"
  },
  "dependencies": {
    "@codemod-utils/ast-javascript": "^4.0.2",
    "@codemod-utils/ast-template": "^4.0.0",
    "@codemod-utils/ast-template-tag": "^2.6.0",
    "@codemod-utils/files": "^4.0.1",
    "@codemod-utils/package-json": "^4.0.3",
    "@codemod-utils/threads": "^1.0.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@codemod-utils/tests": "^3.0.2",
    "@shared-configs/eslint-config-node": "workspace:*",
    "@shared-configs/prettier": "workspace:*",
    "@shared-configs/typescript": "workspace:*",
    "@sondr3/minitest": "^0.1.2",
    "@types/node": "^20.19.43",
    "@types/yargs": "^17.0.35",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "22.* || >= 24"
  }
}
