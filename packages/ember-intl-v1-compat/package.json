{
  "name": "@ember-intl/v1-compat",
  "version": "2.0.0-beta.1",
  "description": "Loads translations in v1 apps with ember-intl",
  "keywords": [
    "ember",
    "ember-addon",
    "ember-intl",
    "i18n",
    "internationalization"
  ],
  "homepage": "https://ember-intl.github.io/ember-intl/",
  "repository": {
    "type": "git",
    "url": "https://github.com/ember-intl/ember-intl.git",
    "directory": "packages/ember-intl-v1-compat"
  },
  "license": "MIT",
  "scripts": {
    "build": "ember build --environment=production",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "start": "ember serve",
    "test": "ember test --test-port 0"
  },
  "dependencies": {
    "@babel/core": "^7.29.7",
    "broccoli-caching-writer": "^3.1.0",
    "broccoli-funnel": "^4.0.0",
    "broccoli-merge-trees": "^4.2.0",
    "broccoli-source": "^3.0.1",
    "calculate-cache-key-for-tree": "^2.0.0",
    "ember-auto-import": "^2.13.1",
    "ember-cli-babel": "^8.3.1",
    "extend": "^3.0.2",
    "js-yaml": "^5.2.1",
    "json-stable-stringify": "^1.3.0"
  },
  "devDependencies": {
    "@ember/optional-features": "^3.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.3",
    "@embroider/test-setup": "^4.0.0",
    "@glimmer/component": "^2.1.1",
    "@glimmer/tracking": "^1.1.2",
    "@shared-configs/eslint-config-ember": "workspace:*",
    "@shared-configs/prettier": "workspace:*",
    "@shared-configs/testem": "workspace:*",
    "concurrently": "^10.0.3",
    "ember-cli": "~7.1.0",
    "ember-cli-htmlbars": "^7.0.1",
    "ember-load-initializers": "^3.0.1",
    "ember-qunit": "^9.1.0",
    "ember-resolver": "^13.2.0",
    "ember-source": "~7.1.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "loader.js": "^4.7.0",
    "prettier": "^3.9.6",
    "qunit": "^2.26.0",
    "qunit-dom": "^3.6.0",
    "webpack": "^5.108.4"
  },
  "engines": {
    "node": "22.* || >= 24"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "configPath": "tests/dummy/config",
    "demoURL": "https://ember-intl.github.io/ember-intl/"
  }
}
