{
  "name": "@shared-configs/eslint-config-node",
  "version": "0.0.0",
  "private": true,
  "description": "Configuration for eslint (Node)",
  "repository": {
    "type": "git",
    "url": "https://github.com/ember-intl/ember-intl.git"
  },
  "author": "Isaac J. Lee",
  "type": "module",
  "exports": {
    "./javascript": "./javascript/index.mjs",
    "./typescript": "./typescript/index.mjs"
  },
  "scripts": {
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix"
  },
  "dependencies": {
    "@ijlee2-frontend-configs/eslint-config-node": "^4.1.0"
  },
  "devDependencies": {
    "@shared-configs/prettier": "workspace:*",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4"
  },
  "peerDependencies": {
    "eslint": "^10.6.0",
    "typescript": "^6.0.3"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": false
    },
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": "20.* || >= 22"
  }
}
