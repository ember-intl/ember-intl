{
  "extends": "@shared-configs/typescript/ember",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "my-app-with-fallbacks/tests/*": ["tests/*"],
      "my-app-with-fallbacks/*": ["app/*"],
      "my-v1-addon/*": ["../my-v1-addon/addon/*"],
      "*": ["types/*"]
    },
    "skipLibCheck": true,
    "types": [
      "ember-source/types"
    ]
  },
  "glint": {
    "environment": [
      "ember-loose",
      "ember-template-imports"
    ]
  }
}
