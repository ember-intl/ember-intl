{
  "extends": "@shared-configs/typescript/ember-addon",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "paths": {
      "dummy/tests/*": ["./tests/*"],
      "dummy/*": ["./tests/dummy/app/*"],
      "my-v1-engine": ["./addon"],
      "my-v1-engine/*": ["./addon/*"],
      "my-v1-engine/test-support": ["./addon-test-support"],
      "my-v1-engine/test-support/*": ["./addon-test-support/*"],
      "*": ["./types/*"]
    },
    "rootDir": ".",
    "types": ["ember-source/types"]
  },
  "glint": {
    "environment": ["ember-loose", "ember-template-imports"]
  },
  "include": [
    "addon/**/*",
    "addon-test-support/**/*",
    "tests/**/*",
    "types/**/*"
  ]
}
