{
  "name": "my-v2-app-with-namespace-from-folders",
  "version": "1.6.0",
  "private": true,
  "description": "A Vite app to test namespaceKeysByDir",
  "repository": {
    "type": "git",
    "url": "https://github.com/ember-intl/ember-intl.git"
  },
  "author": "Isaac J. Lee",
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "scripts": {
    "build": "vite build",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:intl": "ember-intl-lint",
    "lint:intl:fix": "ember-intl-lint --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "ember-tsc --noEmit",
    "start": "vite",
    "test": "NODE_ENV=development vite build --mode development && ember test --path dist --test-port 0"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/plugin-transform-runtime": "^8.0.1",
    "@babel/plugin-transform-typescript": "^8.0.1",
    "@ember-intl/lint": "workspace:*",
    "@ember-intl/vite": "workspace:*",
    "@ember/optional-features": "^3.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.3",
    "@embroider/compat": "^4.1.21",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^4.6.2",
    "@embroider/router": "^3.0.6",
    "@embroider/vite": "^1.7.8",
    "@glimmer/component": "^2.1.1",
    "@glimmer/tracking": "^1.1.2",
    "@glint/ember-tsc": "^1.8.12",
    "@glint/template": "^1.7.8",
    "@rollup/plugin-babel": "^7.1.0",
    "@shared-configs/eslint-config-ember": "workspace:*",
    "@shared-configs/eslint-config-yaml": "workspace:*",
    "@shared-configs/prettier": "workspace:*",
    "@shared-configs/testem": "workspace:*",
    "@shared-configs/typescript": "workspace:*",
    "@types/qunit": "^2.19.14",
    "babel-plugin-ember-template-compilation": "^4.0.0",
    "concurrently": "^10.0.3",
    "decorator-transforms": "^2.4.0",
    "ember-cli": "~7.1.0",
    "ember-cli-babel": "^8.3.1",
    "ember-intl": "workspace:*",
    "ember-load-initializers": "^3.0.1",
    "ember-page-title": "^9.0.3",
    "ember-qunit": "^9.1.0",
    "ember-resolver": "^13.2.0",
    "ember-source": "~7.1.0",
    "eslint": "^10.7.0",
    "my-v1-addon": "workspace:*",
    "my-v2-addon": "workspace:*",
    "prettier": "^3.9.5",
    "qunit": "^2.26.0",
    "qunit-dom": "^3.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4"
  },
  "engines": {
    "node": "22.* || >= 24"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "type": "app",
    "version": 2
  }
}
