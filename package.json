{
  "name": "workspace-root",
  "version": "8.4.1",
  "private": true,
  "description": "Workspace root for ember-intl",
  "repository": {
    "type": "git",
    "url": "https://github.com/ember-intl/ember-intl.git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm build:packages && pnpm build:my-v2-addon",
    "build:my-v2-addon": "pnpm --filter my-v2-addon build",
    "build:packages": "pnpm --filter \"./packages/**\" build",
    "format": "pnpm --filter \"*\" format",
    "lint": "pnpm --filter \"*\" lint && pnpm lint:package-json",
    "lint:fix": "pnpm --filter \"*\" lint:fix && pnpm lint:package-json:fix",
    "lint:package-json": "pnpm lint:package-json:fix --check",
    "lint:package-json:fix": "sort-package-json \"**/package.json\" --ignore \"**/{blueprints,dist,dist-for-testing,node_modules,tests,tmp}/**\"",
    "prepare": "pnpm build",
    "release:prepare": "changeset version; update-workspace-root-version",
    "release:publish": "pnpm build:packages && changeset publish",
    "start": "pnpm --filter docs-app-for-ember-intl start",
    "test": "pnpm --filter \"*\" test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@ijlee2-frontend-configs/changesets": "^2.1.1",
    "sort-package-json": "^4.0.0",
    "update-workspace-root-version": "^3.0.4"
  },
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": "22.* || >= 24",
    "pnpm": ">= 10"
  },
  "pnpm": {
    "overrides": {
      "ember-cli-htmlbars": "^7.0.1",
      "vite": "^8.1.4"
    }
  }
}
